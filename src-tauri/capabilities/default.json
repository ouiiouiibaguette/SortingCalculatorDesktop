{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "fs:default",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-copy-file",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:scope-appdata-recursive",
    "fs:scope-desktop-recursive",
    "fs:scope-document-recursive",
    "dialog:default"
  ]
}